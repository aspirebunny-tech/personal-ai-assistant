<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.personalai.watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/aspirebunny/Library/Application Support/personal-ai-assistant/scripts/pai_watchdog.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/aspirebunny/Desktop/personal-ai-assistant</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>PAI_PROJECT_ROOT</key>
    <string>/Users/aspirebunny/Desktop/personal-ai-assistant</string>
    <key>PAI_SERVER_DIR</key>
    <string>/Users/aspirebunny/Desktop/personal-ai-assistant/server</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>45</integer>

  <key>StandardOutPath</key>
  <string>/tmp/pai_watchdog.launchd.out</string>

  <key>StandardErrorPath</key>
  <string>/tmp/pai_watchdog.launchd.err</string>
</dict>
</plist>
