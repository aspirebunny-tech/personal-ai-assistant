# ================================
# Personal AI Assistant - Config
# ================================

# Server
PORT=3000
JWT_SECRET=apna_koi_bhi_secret_yahan_likho_jaise_meri_notes_app_2024

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_FALLBACK_MODEL=qwen/qwen3.5-flash-02-23

# OpenAI STT Fallback (for high-accuracy speech transcription)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_STT_MODEL=gpt-4o-transcribe
STT_LOCAL_CONFIDENCE_THRESHOLD=0.55
LOCAL_WHISPER_BIN=whisper
LOCAL_WHISPER_MODEL=small
LOCAL_FFMPEG_BIN=ffmpeg

# File Upload
MAX_FILE_SIZE_MB=100
UPLOAD_PATH=./uploads
